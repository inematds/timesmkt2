        "zoom": { "start": 1.0, "end": 1.2, "progression": "exponential" }
      },
      "ffmpeg": "scale=1080:1920:force_original_aspect_ratio=increase,crop=1080:1920",
      "color": { "gamma": 1.1, "saturate": 1.2, "contrast": 1.15, "hueRotate": 0 },
      "motion_blur": "shutter_180",
      "grain": 0,
      "speed_ramp": "frequent",
      "camera_shake": "light",
      "cut_rhythm": "very_fast",
      "fps": 30,
      "bitrate": "-crf 23",
      "safe_zone": { "top": "20%", "bottom": "20%", "content": "60% center" },
      "max_clip_duration": 2.5,
      "transitions": ["quick_cuts", "sharp_cuts", "punch_zoom"],
      "mood": "retention, addictive",
      "pro_secret": "Change angle/zoom every 2.5s; safe zone 60% center"
    },
    "20_performance_ad": {
      "label": "Performance Ad (Venda Direta)",
      "remotion": {
        "easing": "Easing.out(Easing.back)",
        "spring": { "mass": 0.5, "stiffness": 300, "damping": 10 },
