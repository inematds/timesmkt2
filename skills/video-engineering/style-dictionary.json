      "bitrate": "-crf 20",
      "transitions": ["clean_cut"],
      "mood": "clarity, confidence",
      "pro_secret": "Rim light simulation; sharp focus on product"
    },
    "03_explainer": {
      "label": "Explainer Video",
      "remotion": {
        "easing": "Easing.bezier(0.25, 0.1, 0.25, 1)",
