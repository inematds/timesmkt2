        "zoom": { "start": 1.0, "end": 1.05, "progression": "linear" }
      },
      "ffmpeg": "scale=1920:-2,fps=30",
      "color": { "gamma": 1.0, "saturate": 1.0, "contrast": 1.0, "hueRotate": 0 },
