    "10_problem_solution": {
      "label": "Problema e Solução",
      "remotion": {
        "easing_problem": "Easing.linear",
        "easing_solution": "Easing.out(Easing.back)",
        "spring": { "mass": 0.8, "stiffness": 200, "damping": 12 },
        "zoom": { "start": 1.0, "end": 1.15, "progression": "exponential" }
      },
      "ffmpeg": "split[a][b];[a]curves...",
      "color_problem": { "gamma": 1.0, "saturate": 0.8, "contrast": 1.0, "hueRotate": 0 },
      "color_solution": { "gamma": 1.1, "saturate": 1.3, "contrast": 1.1, "hueRotate": 0 },
      "motion_blur": "shutter_120",
      "grain": 0.01,
      "speed_ramp": "on_transition",
      "camera_shake": "light_problem_none_solution",
      "cut_rhythm": "increasing",
      "fps": 30,
      "bitrate": "-crf 20",
      "transitions": ["dry_cut", "dynamic_transition", "whip_pan"],
      "mood": "relief, resolution",
      "pro_secret": "Grayscale→Color transition; Mono/lowpass audio (problem) → Stereo (solution)"
    },
    "13_kinetic_typography": {
      "label": "Kinetic Typography",
      "remotion": {
        "easing": "Easing.backOut",
        "spring": { "mass": 0.5, "stiffness": 250, "damping": 8 },
        "zoom": { "start": 1.0, "end": 1.15, "progression": "exponential" }
      },
      "ffmpeg": "drawtext=fontfile=bold.ttf...alpha='if(lt(t,0.5),t/0.5,1)'",
      "color": { "gamma": 1.05, "saturate": 1.1, "contrast": 1.2, "hueRotate": 0 },
      "motion_blur": "none",
      "grain": 0,
      "speed_ramp": "none",
      "camera_shake": "none",
      "cut_rhythm": "sync_audio_transients",
      "fps": 30,
      "bitrate": "-crf 20",
      "transitions": ["rhythmic_cuts", "typographic_animation"],
      "mood": "impact, memorization",
      "pro_secret": "Text appears 1 frame BEFORE audio transient; high contrast fonts"
    },
    "14_short_vertical": {
      "label": "Short Vertical (Reels/TikTok/Shorts)",
