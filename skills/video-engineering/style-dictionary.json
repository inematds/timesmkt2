{
  "styles": {
    "01_hero_film": {
      "label": "Cinematográfico de Marca (Hero Film)",
      "remotion": {
        "easing": "Easing.inOut(Easing.quad)",
        "spring": { "mass": 1, "stiffness": 40, "damping": 20 },
        "zoom": { "start": 1.0, "end": 1.1, "progression": "logarithmic" }
      },
      "ffmpeg": "curves=vintage,format=yuv422p10le,noise=alls=3:allf=t+u",
      "color": { "gamma": 1.05, "saturate": 1.1, "contrast": 1.05, "hueRotate": 0 },
      "motion_blur": "none",
      "grain": 0.02,
      "speed_ramp": "key_moments_only",
      "camera_shake": "minimal",
      "cut_rhythm": "slow_to_climax",
      "fps": 24,
      "bitrate": "-crf 17",
      "letterbox": "2.35:1",
      "transitions": ["clean_cut", "subtle_fade", "light_whip_pan"],
      "mood": "desire, sophistication, premium",
      "pro_secret": "Add Letterbox 2.35:1; 10-bit color; grain"
    },
    "02_product_demo": {
      "label": "Product Demo",
      "remotion": {
        "easing": "Easing.out(Easing.quad)",
        "spring": { "mass": 1, "stiffness": 50, "damping": 20 },
        "zoom": { "start": 1.0, "end": 1.08, "progression": "linear" }
      },
      "ffmpeg": "unsharp=luma_msize_x=7:luma_msize_y=7:luma_amount=0.8",
      "color": { "gamma": 1.0, "saturate": 1.0, "contrast": 1.05, "hueRotate": 0 },
      "motion_blur": "none",
      "grain": 0,
      "speed_ramp": "optional",
      "camera_shake": "none",
