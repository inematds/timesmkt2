  "universal_rules": {
    "safe_zones_vertical": { "top_margin": "20%", "bottom_margin": "30%", "safe_content": "20%-70%" },
    "text_appears_before_audio": 1,
    "cut_before_audio_transient": 2,
    "min_font_size_1080p": 60,
    "max_words_overlay": 6,
    "never_100_percent_cuts": true,
    "crossfade_between_sections": true,
    "min_zoom_intensity": 1.06,
    "color_grading_unified": true
